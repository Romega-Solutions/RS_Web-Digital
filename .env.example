# App URLs
NEXT_PUBLIC_SITE_URL=https://www.romega-solutions.com

# Contact form email provider (required in production for /api/contact)
RESEND_API_KEY=your-resend-api-key
ADMIN_EMAIL=info@romega-solutions.com

# Optional anti-spam verification.
# Only enable this after wiring a client-side recaptcha token into the contact form payload.
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key
RECAPTCHA_TIMEOUT_MS=5000

# Optional Google Apps Script endpoint for live job listings.
# If omitted, /api/careers/jobs uses the built-in fallback endpoint.
JOBS_API_URL=your-google-apps-script-url

# Local-only dev convenience: capture form submissions without RESEND_API_KEY (set true only for dev).
EMAIL_CONTACT_FALLBACK_ENABLED=false
